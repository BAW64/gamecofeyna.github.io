        <!-- Секция "Топ старых игр" -->
        <section id="old-games" class="section">
            <h1>Топ старых игр</h1>
            <div class="game-list" id="oldGamesList"></div>
        </section>

        <!-- Секция "Топ лучших игр" -->
        <section id="top-games" class="section">
