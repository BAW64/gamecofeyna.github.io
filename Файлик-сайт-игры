        // Переключение секций
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const sectionId = link.getAttribute('data-section');
                showSection(sectionId);
            });
        });

        function showSection(sectionId) {
            // Скрываем все секции
            document.querySelectorAll('.section').forEach(section => {
                section.classList.remove('active');
            });

            // Показываем нужную секцию
            document.getElementById(sectionId).classList.add('active');

            // Обновляем список игр для соответствующих секций
            if (sectionId === 'new-games') {
                renderGames(getNewGames(), 'newGamesList');
            } else if (sectionId === 'old-games') {
                renderGames(getOldGames(), 'oldGamesList');
            } else if (sectionId === 'top-games') {
                renderGames(getTopGames(), 'topGamesList');
            }
        }

        // Получение новых игр (последние 5 лет)
        function getNewGames() {
            const currentYear = new Date().getFullYear();
            return games.filter(game => game.releaseDate >= currentYear - 5);
        }

        // Получение старых игр (старше 5 лет)
        function getOldGames() {
            const currentYear = new Date().getFullYear();
            return games.filter(game => game.releaseDate < currentYear - 5);
        }

        // Получение топ игр (по рейтингу)
        function getTopGames() {
            return [...games].sort((a, b) => b.rating - a.rating);
        }

        // Отрисовка списка игр
        function renderGames(gamesList, containerId) {
            const container = document.getElementById(containerId);
            container.innerHTML = '';

            gamesList.forEach((game, index) => {
                const gameItem = document.createElement('div');
                gameItem.className = 'game-item';
                gameItem.innerHTML = `
                    <div class="game-number">${index + 1}</div>
                    <img src="${game.images[0]}" alt="${game.title}" class="game-image">
                    <div class="game-info">
                        <h3>${game.title}</h3>
                        <p>${game.description}</p>
                    </div>
                `;
                gameItem.addEventListener('click', () => showGamePage(game.id));
                container.appendChild(gameItem);
            });
        }

        // Показ страницы игры
        function showGamePage(gameId) {
            const game = games.find(g => g.id === gameId);
            if (!game) return;

            showSection('game-page');

            document.getElementById('game-main-image').src = game.images[0];
            document.getElementById('game-title').textContent = game.title;
            document.getElementById('game-description').textContent = game.description;

            const gallery = document.getElementById('game-gallery');
            gallery.innerHTML = '';

            game.images.forEach(imgSrc => {
                const img = document.createElement('img');
                img.src = imgSrc;
                img.alt = game.title;
                gallery.appendChild(img);
            });
        }

        // Возврат к списку игр
        function goBack() {
            window.history.back();
        }

        // Переключение темы
        const themeToggle = document.getElementById('themeToggle');
        const currentTheme = localStorage.getItem('theme') || 'light';

        if (currentTheme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            themeToggle.textContent = 'Светлая тема';
        }

        themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            if (currentTheme === 'dark') {
                document.documentElement.removeAttribute('data-theme');
                localStorage.setItem('theme', 'light');
                themeToggle.textContent = 'Тёмная тема';
            } else {
                document.documentElement.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
                themeToggle.textContent = 'Светлая тема';
            }
        });

        // Модальное окно обратной связи
        function openModal() {
            document.getElementById('feedbackModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('feedbackModal').classList.remove('active');
        }

        // Обработка формы обратной связи
        document.getElementById('feedbackForm').addEventListener('submit', (e) => {
            e.preventDefault();

            const formData = {
                name: document.getElementById('name').value,
                email: document.getElementById('email').value,
                message: document.getElementById('message').value
            };

            // email
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(formData.email)) {
                alert('Пожалуйста, введите корректный email адрес');
                return;
            }

            console.log('Данные формы:', formData);
            alert('Сообщение отправлено!');
            closeModal();
            document.getElementById('feedbackForm').reset();
        });

        // Инициализация при загрузке страницы
        document.addEventListener('DOMContentLoaded', () => {
            // Добавляем обработчик для открытия модального окна (можно добавить кнопку в интерфейс)
            // Для примера добавим кнопку в футер:
            const footer = document.querySelector('footer');
            const feedbackBtn = document.createElement('button');
            feedbackBtn.textContent = 'Обратная связь';
            feedbackBtn.style.marginTop = '1rem';
            feedbackBtn.addEventListener('click', openModal);
            footer.appendChild(feedbackBtn);

            // Изначально показываем секцию "О нас"
            showSection('about');
        });
    </script>
</body>
</html>
