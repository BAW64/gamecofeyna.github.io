                <button type="submit">Отправить</button>
            </form>
        </div>
    </div>

    <footer>
        <p>Автор сайта: Влад Шишкин Егорович</p>
        <p>Email: dmitriip-11@mail.ru</p>
        <p>Телеграм-канал: <a href="https://t.me/gamekofeyna">gamekofeyna</a></p>
    </footer>

    <script>
        // Данные игр
        const games = [
            { id: 1, title: "Minecraft", description: "Окунитесь в мир кубической песочницы, которая уже успела стать культовой и иконой индустрии! Созидайте, разрушайте, веселителитесь с друзьями и просто выживайте в по истине легендарной игре.", releaseDate: 2011, rating: 9.9, top: true, images: ["img_2.png", "img_3.png", "img_4.png", "img_5.png", "img_6.png", "img_7.png"] },
            { id: 2, title: "RUST", description: "Ржавчина (в переводе на русский) - игра для настоящих хардкорщиков с высоким порогом вхождения. Почувствуйте себя в роли выжившего на, имеющем заброшенную инфраструктуру, необитаемом острове... или, все же, обитаемом? Охотьтесь, стройте, изучайте технологии, исследуйте РТ, участвуйте в ивентах, обзаводитесь врагами и друзьями, ищите легендарный лут и постарайтесь не потерять все в гонке за ресурсами.", releaseDate: 2013, rating: 9.4, top: false, images: ["img_14.png", "img_15.png", "img_16.png", "img_17.png", "img_18.png", "img_19.png"] },
            { id: 3, title: "SUBNAUTICA", description: "Вы - один из членов экипажа космического корабля, который потерпел крушение на неизвестной планете, почти всю поверхность которой покрывает вода. Начиная с маленькой капсулы и 'мелководья', постройте настоящую подводную лабораторию и исследуйте самые темные глубины океана.", releaseDate: 2018, rating: 9.8, top: true, images: ["img_8.png", "img_9.png", "img_10.png", "img_11.png", "img_12.png", "img_13.png"] },
                { id: 4, title: "Escape from DUCKOV", description: "Многим игра покажется просто всратой пародией на Escape from Tarkov, хотя на своем релизе она собрала больший онлайн, чем оригинал. Возьмите на себя роль мультяшной утки, собирайте ресурсы и оружие, прокачивайте свою базу, покупайте улучшения и снаряжение. Очень залипательная инди-стрелялка, которая нравится игрокам больше, чем игра, с которой этот проект брал пример.", releaseDate: 2025, rating: 9.5, top: false, images: ["img_20.png", "img_21.png", "img_22.png", "img_23.png", "img_24.png", "img_25.png"] },
            { id: 5, title: "BeamNG.drive", description: "Устали от казуальных гонок и нереалистичной физики авто? У 'Бимки' все то, что есть в реальной жизни: хорошая графика, реалистичная коробка передач ('акрадный режим' присутствует) и реалистичные повреждения. МНОГО реалистичных повреждений. Кроме того, у вас не получится красиво задрифтеть на повороте на любой машине, кинематографично залететь на трамплин или спокойно 'пошашковать', ведь любое неосторожное движение может привести к, например, заносу, оторванному колесу, или Вы просто превратите свою машину в лепешку из-за плохих тормозов. В игре вы можете создавать свои карты, а также поддерживается Steam Workshop, так что скучно вам точно не будет.", releaseDate: 2015, rating: 9.6, top: true, images: ["img_26.png", "img_27.png", "img_28.png", "img_29.png", "img_30.png", "img_31.png"] },
            { id: 6, title: "Barotrauma", description: "Вам и другим игрокам предстоит стать одним из членов экипажа подводной лодки на водной планете, в целях ее изучения и выполнения квестов. Вы - всего лишь винтик в огромной машине, и вместе с коллегами вам придется отбиваться от морских чудовищ, чинить подлодку, вставать на сторону одной фракции, автоматически становясь врагом для другой, и покупать улучшения, чтобы следующая миссия имела шанс на успех.", releaseDate: 2023, rating: 8.9, top: false, images: ["img_32.png", "img_33.png", "img_34.png", "img_35.png", "img_36.png", "img_37.png"] },
            { id: 7, title: "They Killed Your Cat", description: "Не самые добрые люди убили вашего котейку, и теперь вы отправляетесь мстить. На первый взгляд, враги с молотками не кажутся такими уж грозными, особенно учитывая то, что для их убийства требуется всего три пули (одна при хэдшоте), но ровно до того, как вы сделаете первый шаг. Буквально. Перезарядка поделена на дри действия, чтобы ходить, нужно управлять двумя ногами (на A и D), если не моргать - все перед глазами помутнеет, и про дыхание тоже лучше не забывать, чтобы не умереть от удушья. Игра довольно однотипная, особенно учитывая наличие всего трех видов оружия, но хардкорщики оценят.", releaseDate: 2026, rating: 8.6, top: true, images: ["img_38.png", "img_39.png", "img_40.png", "img_41.png", "img_42.png", "img_43.png"] },
            { id: 8, title: "Hollow Knight: SILKSONG", description: "Настоящая пытка даже для хардкорщиков. 2d-платформер с приятной графикой, который игроки ждали еще со времен первой части. Хорнет - главная героиня-жук, в роли которой игроку придется сражаться с монстрами, побеждать боссов и проходить сложнейшие испытания, а также 'впитывать' интересный и продуманный сюжет вместе с пасхалками.", releaseDate: 2025, rating: 9.8, top: false, images: ["img_44.png", "img_45.png", "img_46.png", "img_47.png", "img_48.png", "img_49.png"] },
            { id: 9, title: "Forza horizon 6", description: "Долгожданный гоночный симулятор с кинематографичной графикой, приятным управлением и, как говорят сами игроки, 'нереальной атмосферой Японии'. Высокая скорость, красивые пейзажи и спортивные тачки - именно то, что способно захватить дух любого мужчины.", releaseDate: 2026, rating: 9.7, top: true, images: ["img_50.png", "img_51.png", "img_52.png", "img_53.png", "img_54.png", "img_55.png"] },
            { id: 10, title: "Hytale", description: "Игра от основателей крупного Minecraft-сервера, которая заставила поднапрячся самих Mojang. В первую очередь многие отмечают систему боевки: интереная, с уникальными механиками и разными видами оружия. Как же без строительства: подобно величайшей инди-игре, здесь предоставлена полная свобода, которую можно использовать как душе угодно, в том числе для строительства. В игре также присутствует сюжет, который и ведет нас убивать боссов, исследовать подземелья и данжи. Пока игра в раннем доступе, но мододелы уже создают невообразимое количество контента.", releaseDate: 2026, rating: 9.2, top: false, images: ["img_56.png", "img_57.png", "img_58.png", "img_59.png", "img_60.png", "img_61.png"] },
            { id: 11, title: "R.E.P.O.", description: "Несмотря на свою принадлежность к жанру 'хорроры', ее смело можно назвать одной из самых смешных и необычных игр. Эта игра - духовный наследник Lethal Company, в которой вам и вашим друзьям придется вместе обчищать локации с дорогими предметами и страшными монстрами, а чтобы было удобнее скооперироваться - предоставлен голосовой чат. После завершения уровня, деньги, полученные с зачистки лвл-ов вы можете потратить на улучшения, например, овеличение здоровья, крылышки для полета или даже... пушки? После приобретения оружия (а в некоторых случаях - и ДО этого) вы сможете уничтожать монстров, из которых падают дорогие сферы, полностью покрывающие расходы на боеприпасы. Игра в свое время наделала много шума и до сих пор продолжает активно развиваться.", releaseDate: 2025, rating: 9.4, top: true, images: ["img_63.png", "img_64.png", "img_65.png", "img_66.png", "img_67.png", "img_68.png"] },
            { id: 12, title: "The Long Dark", description: "Вы - один. Вокруг только холод, хищники и голод. С собой у вас только одежда и коробок спичек. Ваше местоположение - ныне неизвестный остров аляски, на котором жили люди, но по неизвестным причинам бросили его. Если от хищников удастся убежать, еду - собрать под деревом или найти в рыбацком домике, то холод - он везде, и побороть его даже с теплой одеждой не так-то просто, ведь любой источники огня или искорки нужно сперва найти, а ресурс это очень редкий и ценной, порой единственным выходом является круглосуточное поддержание огня. Удастся ли вам продержаться здесь в полном одиночестве еще, хотя бы, ночь?..", releaseDate: 2017, rating: 8.8, top: false, images: ["img_69.png", "img_71.png", "img_70.png", "img_72.png", "img_73.png", "img_74.png"] },
